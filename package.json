{
  "name": "gcds-map",
  "version": "1.0.0-rc",
  "description": "Government of Canada Design System map component suite",
  "repository": {
    "type": "git",
    "url": "https://github.com/NRCan/gcds-map.git"
  },
  "files": [
    "dist/gcds-map/"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-locale.js",
    "build": "stencil build",
    "prestart": "node scripts/generate-locale.js",
    "start": "concurrently \"npm run start:stencil\" \"npm run start:express\"",
    "start:stencil": "stencil build --dev --watch --serve",
    "start:express": "node test-server.js",
    "test": "playwright test --workers=1 --retries=2",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build -o ./docs",
    "test:e2e": "playwright test",
    "deploy": "bash scripts/deploy-gh-pages.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@gcds-core/fonts": "^1.1.0",
    "@gcds-core/tokens": "^1.5.0",
    "@playwright/test": "^1.54.0",
    "@stencil/core": "^4.43.4",
    "@stencil/playwright": "^0.2.1",
    "@storybook/addon-actions": "^8.0.9",
    "@storybook/addon-essentials": "^8.0.9",
    "@storybook/addon-interactions": "^8.0.9",
    "@storybook/addon-links": "^8.0.9",
    "@storybook/addon-mdx-gfm": "^8.0.9",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.3",
    "@storybook/blocks": "^8.0.9",
    "@storybook/html": "^8.0.9",
    "@storybook/html-webpack5": "^8.0.9",
    "@types/node": "^22.16.2",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "leaflet.locatecontrol": "^0.90.0",
    "mapml-extension": "git+https://github.com/Maps4HTML/mapml-extension",
    "media-query-parser": "^3.0.2",
    "media-query-solver": "^0.1.3",
    "postcss-import": "^16.1.1",
    "proj4": "^2.6.2",
    "proj4leaflet": "git+https://github.com/Maps4HTML/proj4leaflet.git#es-module",
    "protomaps-leaflet": "^4.0.1",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "serve": "^14.2.4",
    "serve-static": "^2.2.0",
    "ts-loader": "^9.5.2"
  },
  "license": "MIT",
  "dependencies": {
    "@storybook/addon-a11y": "^8.0.9",
    "@storybook/addons": "^7.6.17",
    "@storybook/test": "^8.0.9",
    "@storybook/theming": "^8.0.9",
    "axe-core": "^4.10.3",
    "prettier": "^3.6.2",
    "prismjs": "^1.30.0"
  },
  "peerDependencies": {
    "@gcds-core/components": "^1.3.0"
  }
}
